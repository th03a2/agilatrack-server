NODE_ENV=development
HOST=0.0.0.0
PORT=5000

MONGO_URI=mongodb+srv://YOUR_ATLAS_USER:YOUR_ATLAS_PASSWORD@YOUR_CLUSTER.mongodb.net/agilatrack
MONGO_SERVER_SELECTION_TIMEOUT_MS=15000

CLIENT_URL=http://localhost:5173
CLIENT_URLS=http://localhost:4173,http://127.0.0.1:5173,http://127.0.0.1:4173
CORS_ORIGINS=

AUTH_TOKEN_SECRET=replace-with-a-long-random-secret
JWT_SECRET=replace-with-a-long-random-secret
AUTH_TOKEN_TTL_SECONDS=2592000
AUTH_TOKEN_ISSUER=agilatrack
AUTH_TOKEN_AUDIENCE=agilatrack-users

AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=20
AUTH_VERIFICATION_RESEND_COOLDOWN_SECONDS=40
AUTH_VERIFICATION_MAX_ATTEMPTS=5
AUTH_EXPOSE_VERIFICATION_CODE=false
AUTH_STATIC_VERIFICATION_CODE=

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=AgilaTrack <no-reply@example.com>
SMTP_SECURE=false

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
