NODE_ENV=development
HOST=0.0.0.0
PORT=5000
APP_VERSION=1.0.0
SERVER_URL=http://localhost:5000
PUBLIC_API_URL=http://localhost:5000
API_PUBLIC_URL=http://localhost:5000

MONGO_URI=mongodb+srv://YOUR_ATLAS_USER:YOUR_ATLAS_PASSWORD@YOUR_CLUSTER.mongodb.net/agilatrack
MONGO_SERVER_SELECTION_TIMEOUT_MS=15000

CLIENT_URL=http://localhost:5173
CLIENT_URLS=http://localhost:4173,http://127.0.0.1:5173,http://127.0.0.1:4173
CORS_ORIGINS=
FRONTEND_URL=http://localhost:5173
WEB_APP_URL=http://localhost:5173

AUTH_TOKEN_SECRET=replace-with-a-long-random-secret
JWT_SECRET=replace-with-a-long-random-secret
AUTH_TOKEN_TTL_SECONDS=2592000
AUTH_TOKEN_ISSUER=agilatrack
AUTH_TOKEN_AUDIENCE=agilatrack-users

AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=20
AUTH_VERIFICATION_RESEND_COOLDOWN_SECONDS=40
AUTH_VERIFICATION_MAX_ATTEMPTS=5
AUTH_EXPOSE_VERIFICATION_CODE=false
AUTH_STATIC_VERIFICATION_CODE=

# Email Provider Configuration
# Options: gmail, sendgrid, aws_ses, custom
EMAIL_PROVIDER=gmail

# Option 1: Gmail SMTP (Free for personal use)
# Generate App Password: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-gmail-address@gmail.com
SMTP_PASS=your-16-character-app-password
SMTP_FROM=AgilaTrack <your-gmail-address@gmail.com>
SMTP_SECURE=false

# Option 2: SendGrid (100 emails/day free - Good for startups)
# Get API Key: https://sendgrid.com
# EMAIL_PROVIDER=sendgrid
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_USER=apikey
# SMTP_PASS=your-sendgrid-api-key
# SMTP_FROM=AgilaTrack <no-reply@your-company.com>

# Option 3: Google Workspace (Professional for companies)
# Setup: https://workspace.google.com
# EMAIL_PROVIDER=gmail
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=no-reply@your-company.com
# SMTP_PASS=your-google-workspace-app-password
# SMTP_FROM=AgilaTrack <no-reply@your-company.com>

# Option 4: AWS SES (62,000 emails/month free - Enterprise)
# Setup: https://aws.amazon.com/ses
# EMAIL_PROVIDER=aws_ses
# SMTP_HOST=email-smtp.us-east-1.amazonaws.com
# SMTP_PORT=587
# SMTP_USER=your-aws-ses-smtp-username
# SMTP_PASS=your-aws-ses-smtp-password
# SMTP_FROM=AgilaTrack <no-reply@your-company.com>

# Alternative Email Configuration (Legacy support)
EMAIL_FROM=AgilaTrack <no-reply@agilatrack.com>
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USER=your-gmail-address@gmail.com
EMAIL_SMTP_PASS=your-16-character-app-password
EMAIL_SMTP_SECURE=false

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

OWNER_ZONE_REAUTH_TTL_SECONDS=300

GOOGLE_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_ID=
FACEBOOK_CLIENT_ID=
FACEBOOK_APP_ID=
